{
  "name": "abdulachik.dev",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "content:index": "content-collections build && bun scripts/generate-search-index.ts",
    "icons:generate": "bun scripts/generate-favicons.ts",
    "dev": "bun run content:index && concurrently --raw \"content-collections watch\" \"next dev\"",
    "build": "bun run content:index && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:config": "cairn config validate --config cairntrace.config.yml",
    "test:e2e": "SKIP_ENV_VALIDATION=1 NEXT_PUBLIC_APP_URL=http://localhost:3000 AGENT_BROWSER_INIT_SCRIPTS=$PWD/node_modules/axe-core/axe.min.js,$PWD/tests/cairn/support/mock-network.js cairn run tests/cairn/flows --backend agent-browser --config cairntrace.config.yml --cold-start --junit test-results/cairn/junit.xml",
    "test:e2e:headed": "SKIP_ENV_VALIDATION=1 NEXT_PUBLIC_APP_URL=http://localhost:3000 AGENT_BROWSER_INIT_SCRIPTS=$PWD/node_modules/axe-core/axe.min.js,$PWD/tests/cairn/support/mock-network.js cairn run tests/cairn/flows --backend agent-browser --config cairntrace.config.yml --cold-start --headed",
    "test:all": "bun run test:coverage && bun run test:e2e",
    "typecheck": "tsc --noEmit --incremental false",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "SKIP_ENV_VALIDATION=1 knip",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test:coverage && bun run knip",
    "ingest": "bun --env-file=.env.local run ./scripts/ingest.ts",
    "codegen": "graphql-codegen --config codegen.mjs",
    "generate": "bun --env-file=.env.local run drizzle-kit generate",
    "migrate": "bun --env-file=.env.local run drizzle-kit migrate",
    "studio": "bun --env-file=.env.local run drizzle-kit studio --port 3001 --verbose",
    "push": "bun --env-file=.env.local run drizzle-kit push",
    "postinstall": "bun run codegen",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^4.0.20",
    "@ai-sdk/openai": "^4.0.14",
    "@apollo/client": "3.14.1",
    "@apollo/server": "5.5.1",
    "@apollo/subgraph": "2.14.2",
    "@apollo/utils.keyvadapter": "^4.0.1",
    "@content-collections/core": "0.15.2",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/next": "0.2.11",
    "@keyv/redis": "^2.7.1",
    "@neondatabase/serverless": "^0.10.0",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-select": "2.3.3",
    "@radix-ui/react-slot": "1.3.0",
    "@solely/simple-fm": "^1.5.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@t3-oss/env-nextjs": "^0.6.1",
    "@upstash/ratelimit": "^0.4.4",
    "@vercel/analytics": "2.0.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "2.0.0",
    "ai": "^7.0.28",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.0.0",
    "drizzle-orm": "0.45.2",
    "geist": "1.7.2",
    "graphql": "16.14.2",
    "graphql-tag": "2.12.7",
    "http-status": "^1.7.0",
    "keyv": "^4.5.3",
    "lodash": "4.18.1",
    "lucide-react": "1.24.0",
    "luxon": "^3.4.3",
    "next": "16.2.10",
    "next-intl": "4.13.2",
    "next-themes": "0.4.6",
    "pgvector": "^0.1.5",
    "postcss": "8.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-tweet": "3.3.1",
    "recharts": "3.9.2",
    "resend": "6.17.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@content-collections/cli": "0.1.9",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/introspection": "^4.0.0",
    "@graphql-codegen/typescript": "^4.0.1",
    "@graphql-codegen/typescript-resolvers": "^4.0.1",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/typography": "0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "4.17.24",
    "@types/luxon": "3.7.2",
    "@types/node": "24",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "agent-browser": "0.31.1",
    "axe-core": "^4.12.1",
    "baseline-browser-mapping": "^2.10.43",
    "concurrently": "^10.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-promise": "7.3.0",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "trustedDependencies": [
    "@apollo/protobufjs",
    "@vercel/speed-insights",
    "agent-browser",
    "bufferutil",
    "esbuild",
    "sharp",
    "unrs-resolver"
  ]
}
